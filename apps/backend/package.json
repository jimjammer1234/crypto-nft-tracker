{
  "name": "backend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "@crypto-nft-tracker/shared-types": "workspace:*",
    "drizzle-orm": "^0.36.0",
    "postgres": "^3.4.0",
    "fastify": "^5.1.0",
    "@fastify/websocket": "^11.0.0",
    "@fastify/cors": "^10.0.1",
    "node-cron": "^3.0.3",
    "zod": "^3.24.0",
    "dotenv": "^16.4.0",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "cheerio": "^1.0.0"
  },
  "devDependencies": {
    "drizzle-kit": "^0.28.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0",
    "@types/node": "^22.10.0",
    "@types/node-cron": "^3.0.11"
  }
}
